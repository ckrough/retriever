{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Lint + Format",
      "type": "shell",
      "command": "uv run ruff check src/ tests/ --fix && uv run ruff format src/ tests/",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Backend: Type Check",
      "type": "shell",
      "command": "uv run python -m mypy src/ --strict",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Backend: Test",
      "type": "shell",
      "command": "uv run python -m pytest tests/ --cov=src/retriever --cov-report=term-missing --cov-fail-under=80",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Backend: All Quality Checks",
      "dependsOn": ["Backend: Lint + Format", "Backend: Type Check", "Backend: Test"],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Check",
      "type": "shell",
      "command": "npm run check",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Frontend: E2E",
      "type": "shell",
      "command": "npx playwright test",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "DB: Run Migrations",
      "type": "shell",
      "command": "uv run alembic upgrade head",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": []
    }
  ]
}
