# Database (local default — docker compose postgres on localhost)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/retriever

# Supabase (required for auth — get values from: supabase status -o json)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# OpenAI (for embeddings and moderation)
OPENAI_API_KEY=your-openai-api-key

# Langfuse (LLM observability — optional)
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Cloudflare AI Gateway (optional — routes through gateway when set)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_GATEWAY_ID=your-gateway-id

# GCP (optional)
GCP_PROJECT_ID=retriever-prod

# OpenTelemetry (set for local Jaeger — docker compose exposes 4317)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# App
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173"]
